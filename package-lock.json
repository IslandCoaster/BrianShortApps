{
  "name": "brianshortapps",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "brianshortapps",
      "version": "1.0.0",
      "workspaces": [
        "applications/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=22"
      }
    },
    "applications/platform-console": {
      "name": "@bsa/platform-console",
      "version": "0.1.0",
      "dependencies": {
        "@bsa/auth": "*",
        "@bsa/design-system": "*",
        "@bsa/diagnostics": "*",
        "@bsa/registry": "*",
        "@bsa/ui": "*"
      }
    },
    "node_modules/@bsa/auth": {
      "resolved": "packages/auth",
      "link": true
    },
    "node_modules/@bsa/aws": {
      "resolved": "packages/aws",
      "link": true
    },
    "node_modules/@bsa/design-system": {
      "resolved": "packages/design-system",
      "link": true
    },
    "node_modules/@bsa/diagnostics": {
      "resolved": "packages/diagnostics",
      "link": true
    },
    "node_modules/@bsa/platform-console": {
      "resolved": "applications/platform-console",
      "link": true
    },
    "node_modules/@bsa/registry": {
      "resolved": "packages/registry",
      "link": true
    },
    "node_modules/@bsa/ui": {
      "resolved": "packages/ui",
      "link": true
    },
    "packages/auth": {
      "name": "@bsa/auth",
      "version": "0.1.0"
    },
    "packages/aws": {
      "name": "@bsa/aws",
      "version": "0.1.0"
    },
    "packages/design-system": {
      "name": "@bsa/design-system",
      "version": "0.1.0"
    },
    "packages/diagnostics": {
      "name": "@bsa/diagnostics",
      "version": "0.1.0"
    },
    "packages/registry": {
      "name": "@bsa/registry",
      "version": "0.1.0"
    },
    "packages/ui": {
      "name": "@bsa/ui",
      "version": "0.1.0"
    }
  }
}
